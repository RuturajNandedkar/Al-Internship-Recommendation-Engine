# ─── Frontend Environment Variables ────────────────────────────────────
# All VITE_ prefixed variables are exposed to the frontend at build time.

# Google Gemini AI — Client-side AI recommendations (free tier available)
# Get your free API key from https://aistudio.google.com/apikey
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Backend API URL — Where the Express backend is hosted
# Local development: http://localhost:5000
# Production (Render): https://your-app.onrender.com
# Production (Railway): https://your-app.up.railway.app
VITE_BACKEND_URL=http://localhost:5000
